/// ### %%matrix.get
///
/// Extracts an element from a matrix using a %%matrix.Idx
// axm %matrix.get: [mat: %matrix.Mat, idx: %matrix.Idx] → mat#data#T, normalize_get;
///
/// ### %%matrix.get1d
///
/// Extracts an element from a matrix using a 1-dimensional array of indices per dimension
// axm %matrix.get1d: [mat: %matrix.Mat, idx: «i: mat#dims#n; Idx (%matrix.shape mat#dims)#i»]
//     → mat#data#T, normalize_get1d;
