// RUN: rm -f %t.ll
// RUN: %mim %s --output-ll %t.ll --device-target nvptx -o -
// RUN: rm -f %t
// RUN: clang %t.ll -o %t -lcuda -Wno-override-module

import gpu;
import nvptx;
import core;
import libc;
import math;
import mem;
import print;

let blockSize = 512;
let gridSize = 8192;
let size = %core.nat.mul (gridSize, blockSize);

let fp_1 = 0x3f800000:%math.F32;
let fp_0_25 = 0x3e800000:%math.F32;
let fp_0_375 = 0x3ec00000:%math.F32;
let fp_25 = 0x41c80000:%math.F32;
let fp_m2 = 0xc0000000:%math.F32;
let fp_0_33 = 0x3eaaaaab:%math.F32;
let fp_pi = 0x40490fdb:%math.F32;


// This is a close re-implementation of A. Karphathy's softmax kernel in llm.c
// see: https://github.com/karpathy/llm.c/blob/f1e2ace651495b74ae22d45d1723443fd00ecd3a/dev/cuda/softmax_forward.cu#L506
con softmax_kernel (m1: %gpu.GlobalM, m3: %gpu.SharedM, m4: %gpu.ConstM, m5: %gpu.LocalM,
                    group_id: Idx gridSize, item_id: Idx blockSize, (), (),
                    (out: %gpu.GlobalPtr «size; %math.F32», inp: %gpu.GlobalPtr «size; %math.F32», N: I32, C: I32),
                    return: Cn [%gpu.GlobalM, %gpu.SharedM, %gpu.ConstM, %gpu.LocalM]) =
    let warpSize = %nvptx.warp_size;

    let (m1, warpsPerBlock) = %core.div.sdiv (m1, (%core.bitcast I32 blockSize, warpSize));
    let tid = %core.bitcast I32 item_id;
    let bid = %core.bitcast I32 group_id;

    let is_idle_thread = %core.icmp.sge (tid, C);
    (continue, return)#is_idle_thread (m1, m3, m4, m5)
    where
        con continue (m1: %gpu.GlobalM, m3: %gpu.SharedM, m4: %gpu.ConstM, m5: %gpu.LocalM) =
            let (m1, warpId) = %core.div.sdiv (m1, (tid, warpSize));
            let (m1, laneId) = %core.div.srem (m1, (tid, warpSize));
            let row = %core.wrap.add 0 (%core.wrap.mul 0 (bid, warpsPerBlock), warpId);

            let is_idle_row = %core.icmp.sge (row, N);
            (calc_softmax, return)#is_idle_row (m1, m3, m4, m5)
            where
                con calc_softmax (m1: %gpu.GlobalM, m3: %gpu.SharedM, m4: %gpu.ConstM, m5: %gpu.LocalM) =
                    let IdxC = Idx (%core.bitcast Nat C);
                    // x is only used for reading - wrap pointer arithmetic in lambda for reading
                    lam x (m1: %gpu.GlobalM, i: IdxC) : [%gpu.GlobalM, %math.F32] =
                        let xIdx = %core.bitcast (Idx size) (%core.wrap.mul 0 (row, C));
                        let idx = %core.wrap.add 0 (xIdx, %core.bitcast (Idx size) i);
                        let addr = %mem.lea (inp, idx);
                        %mem.load (m1, addr);
                    // y is only used for writing - wrap pointer arithmetic in lambda for writing
                    lam y (m1: %gpu.GlobalM, i: IdxC, val: %math.F32) : %gpu.GlobalM =
                        let yIdx = %core.bitcast (Idx size) (%core.wrap.mul 0 (row, C));
                        let idx = %core.wrap.add 0 (yIdx, %core.bitcast (Idx size) i);
                        let addr = %mem.lea (out, idx);
                        %mem.store (m1, addr, val);

                    let maxval = 0xff800000:%math.F32; // = -INFINITY
                    let sumval = 0:%math.F32;
                    fun loopA (m1: %gpu.GlobalM, i: I32, maxval: %math.F32, sumval: %math.F32) =
                        wrapped_loop (m1, i, maxval, sumval, return)
                        where
                            con wrapped_loop (m1: %gpu.GlobalM, i: I32, maxval: %math.F32, sumval: %math.F32,
                                              exit: Cn [%gpu.GlobalM, %math.F32, %math.F32]) =
                                let cond = %core.icmp.sl (i, C);
                                let next_i = %core.wrap.add 0 (i, warpSize);
                                (exit, body)#cond (m1, maxval, sumval)
                                where
                                    con body (m1: %gpu.GlobalM, maxval: %math.F32, sumval: %math.F32) =
                                        let (m1, xi) = x (m1, %core.bitcast IdxC i);
                                        let bigger = %math.extrema.fmax 0 (maxval, xi);
                                        let expf1 = %math.exp.exp 0 (%math.arith.sub 0 (maxval, bigger));
                                        let expf2 = %math.exp.exp 0 (%math.arith.sub 0 (xi, bigger));
                                        let sumval = %math.arith.add 0 (%math.arith.mul 0 (sumval, expf1), expf2);
                                        let maxval = bigger;
                                        wrapped_loop (m1, next_i, maxval, sumval, exit);
                                end;
                        end;
                    ret (m1, maxval, sumval) = loopA $ (m1, laneId, maxval, sumval);

                    let (m1, offset) = %core.div.sdiv (m1, (warpSize, 2I32));

                    fun loopB (m1: %gpu.GlobalM, m5: %gpu.LocalM, offset: I32, maxval: %math.F32, sumval: %math.F32) =
                        wrapped_loop (m1, m5, offset, maxval, sumval, return)
                        where
                            con wrapped_loop (m1: %gpu.GlobalM, m5: %gpu.LocalM,
                                              offset: I32, maxval: %math.F32, sumval: %math.F32,
                                              exit: Cn [%gpu.GlobalM, %gpu.LocalM, %math.F32, %math.F32]) =
                                let cond = %core.icmp.sg (offset, 0I32);
                                let next_offset = %core.shr.a (offset, 1I32);
                                (exit, body)#cond (m1, m5, maxval, sumval)
                                where
                                    con body (m1: %gpu.GlobalM, m5: %gpu.LocalM, maxval: %math.F32, sumval: %math.F32) =
                                        let (m1, m3) = %nvptx.sync_warp_threads (m1, m3, 0xffffffffI32);
                                        let (m5, offsetMaxval) = %nvptx.shfl_sync.down %math.F32
                                                                 (m5, 0xffffffffI32, maxval, offset, 0x1fI32);
                                        let (m5, offsetSumval) = %nvptx.shfl_sync.down %math.F32
                                                                 (m5, 0xffffffffI32, sumval, offset, 0x1fI32);
                                        let if_cond = %math.cmp.g 0 (offsetMaxval, maxval);
                                        (else, then)#if_cond ()
                                        where
                                            con then () =
                                                let expf = %math.exp.exp 0 (%math.arith.sub 0 (maxval, offsetMaxval));
                                                let sumval = %math.arith.mul 0 (sumval, expf);
                                                let maxval = offsetMaxval;
                                                add_and_continue (maxval, sumval, offsetSumval);
                                            con else () =
                                                let expf = %math.exp.exp 0 (%math.arith.sub 0 (offsetMaxval, maxval));
                                                let offsetSumval = %math.arith.mul 0 (offsetSumval, expf);
                                                add_and_continue (maxval, sumval, offsetSumval);
                                            con add_and_continue (maxval: %math.F32, sumval: %math.F32,
                                                                  offsetSumval: %math.F32) =
                                                let sumval = %math.arith.add 0 (sumval, offsetSumval);
                                                wrapped_loop (m1, m5, next_offset, maxval, sumval, exit);
                                        end;

                                end;
                        end;
                    ret (m1, m5, maxval, sumval) = loopB $ (m1, m5, offset, maxval, sumval);

                    let (m5, maxval) = %nvptx.shfl_sync.idx %math.F32 (m5, 0xffffffffI32, maxval, 0I32, 0x1fI32);
                    let (m5, sumval) = %nvptx.shfl_sync.idx %math.F32 (m5, 0xffffffffI32, sumval, 0I32, 0x1fI32);

                    fun loopC (m1: %gpu.GlobalM, i: I32) =
                        wrapped_loop (m1, i, return)
                        where
                            con wrapped_loop (m1: %gpu.GlobalM, i: I32, exit: Cn %gpu.GlobalM) =
                                let cond = %core.icmp.sl (i, C);
                                let next_i = %core.wrap.add 0 (i, warpSize);
                                (exit, body)#cond m1
                                where
                                    con body (m1: %gpu.GlobalM) =
                                        let (m1, xi) = x (m1, %core.bitcast IdxC i);
                                        let expf = %math.exp.exp 0 (%math.arith.sub 0 (xi, maxval));
                                        let div = %math.arith.div 0 (expf, sumval);
                                        let m1 = y (m1, %core.bitcast IdxC i, div);
                                        wrapped_loop (m1, next_i, exit);
                                end;
                        end;
                    ret m1 = loopC $ (m1, laneId);

                    return (m1, m3, m4, m5);
            end;
    end;

fun extern main (m0: %mem.M 0, argc: I32, argv: %mem.Ptr («⊤:Nat; %mem.Ptr («⊤:Nat; I8», 0)», 0)) =
    let (m0, h_in) = %mem.alloc («size; %math.F32», 0) m0;
    let (m0, h_out) = %mem.alloc («size; %math.F32», 0) m0;

    // generate ints in [0, cutoff), convert them to floats in [a, b), and fill h_in with these values
    let seed = 42I32;
    let m0 = %libc.srand (m0, seed);
    let cutoff = 1000000I32;
    let a = %math.minus 0 (%math.conv.s2f %math.f32 2I32);
    let b = %math.conv.s2f %math.f32 2I32;
    let div = %math.arith.div 0 (%math.conv.s2f %math.f32 cutoff, %math.arith.sub 0 (b, a));
    fun loop (m0: %mem.M 0) : %mem.M 0 =
        wrapped_loop (m0, 0I32, return)
        where
            con wrapped_loop (m0: %mem.M 0, i: I32, exit: Cn [%mem.M 0]) =
                let cond = %core.icmp.sl (i, %core.bitcast I32 size);
                let next_i = %core.wrap.add 0 (i, 1I32);
                (exit, body)#cond m0
                where
                    con body (m0: %mem.M 0) =
                        let idx = %core.bitcast (Idx size) i;
                        let addr = %mem.lea (h_in, idx);
                        let (m0, value_i32) = %libc.rand m0;
                        let (m0, value_i32) = %core.div.srem (m0, (value_i32, cutoff));
                        let value = %math.conv.s2f %math.f32 value_i32;
                        let value = %math.arith.div 0 (value, div);
                        let value = %math.arith.add 0 (value, a);
                        let m0 = %mem.store (m0, addr, value);
                        wrapped_loop (m0, next_i, exit);
                end;
        end;
    ret m0 = loop $ m0;


    let (m0, m1, m4, _, _) = %gpu.init (0, 0, m0, (), ());

    let (m0, m1, d_in) = %gpu.alloc_copy.block (m0, m1, h_in);
    let (m0, m1, d_out) = %gpu.alloc_copy.block (m0, m1, h_out);

    let (m0, n) = %core.div.sdiv (m0, (%core.bitcast I32 gridSize, 32I32));
    let c = %core.bitcast I32 blockSize;

    ret m0 = %gpu.launch (m0, gridSize, blockSize, %gpu.default_stream, ff, 0, (), (), ())
             softmax_kernel $ (d_out, d_in, n, c);

    let (m0, m1) = %gpu.copy_to_host.block (m0, m1, d_out, h_out);
    let m1 = %gpu.free.block (m1, d_in);
    let m1 = %gpu.free.block (m1, d_out);

    let m0 = %gpu.deinit (m0, m1, m4);

    ret m0 = %print.arr_f32 $ (m0, size, h_out, 10I32);

    return m0;
