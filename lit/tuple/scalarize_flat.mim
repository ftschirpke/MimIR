// RUN: %mim -p opt %s -o - --scalarize-threshold 16 | FileCheck %s
// RUN: %mim -p opt %s -o - --scalarize-threshold 32 | FileCheck %s --check-prefix=ALMOST-SCALAR
// RUN: %mim -p opt %s -o - --scalarize-threshold 64 | FileCheck %s --check-prefix=SCALAR
plugin tuple;
plugin refly;

con f (t : <<32; Nat>>, r : Cn [<<(32); Nat>>]) = r t;

con extern main(i :(Idx 2), r : Cn [<<32; Nat>>]) = (f (<32; 20>, r), f (<32; 19>, r))#i;

// CHECK-DAG: r_{{[0-9]+}} ‹32; 20›
// CHECK-DAG: r_{{[0-9]+}} ‹32; 19›

// ALMOST-SCALAR-DAG: (20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, 20, eta_r_
// ALMOST-SCALAR-DAG: (19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, 19, eta_r_

// SCALAR-DAG: f_{{[0-9]+}} 20
// SCALAR-DAG: f_{{[0-9]+}} 19
